# Copy to python/.env and fill in for the `publish` command. .env is gitignored.
#
# Same Supabase project as the web app, but the pipeline WRITES, so it needs the
# service-role key (NOT the anon key the browser uses). Never expose this in the
# frontend or commit it. In CI it lives as a GitHub Actions secret.
SUPABASE_URL=https://jkyaxbqoddsznlhipsif.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional: override the on-disk Sleeper cache location (defaults to python/.cache).
# PROJECTIONS_CACHE_DIR=
