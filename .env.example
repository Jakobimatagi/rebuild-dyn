# Copy to .env.local and fill in real values. .env.local is gitignored.

# ─── Required for local dev ────────────────────────────────────────────────
# Supabase — used by Rookie Rankings + Prospector pages.
# Get these from https://supabase.com/dashboard/project/jkyaxbqoddsznlhipsif/settings/api
VITE_SUPABASE_URL=https://jkyaxbqoddsznlhipsif.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── Set in Vercel project env for production ──────────────────────────────
# Optional locally — only needed if you want to exercise AI features in dev.
# Used by all api/ai-*.js handlers. Get from https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=

# ─── Optional dev flag ─────────────────────────────────────────────────────
# Set to "true" to unhide the Strategy Planner tab without the access-code gate.
# VITE_ENABLE_STRATEGY_PLANNER=true
